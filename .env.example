# MySQL — use the database Hostinger provisions for your Node.js app
# (hPanel → Databases → MySQL Databases), or Hostinger's Supabase Postgres
# integration if you'd rather use Postgres.
DATABASE_URL="mysql://username:password@localhost:3306/iqrar_crm"

# Random long string — used to sign admin session cookies.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-long-random-string"

# Object storage for uploads (logo, fleet photos, blog covers, team photos).
# Cloudflare R2 example:
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID="your-r2-access-key-id"
S3_SECRET_ACCESS_KEY="your-r2-secret-access-key"
S3_BUCKET="iqrar-uploads"
S3_PUBLIC_URL_BASE="https://pub-xxxxxxxx.r2.dev"

# If using AWS S3 instead of R2: leave S3_ENDPOINT unset, set S3_REGION to
# your bucket's AWS region (e.g. us-east-1), and set S3_PUBLIC_URL_BASE to
# https://<bucket>.s3.<region>.amazonaws.com
